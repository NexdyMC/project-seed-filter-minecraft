p.z);\r\n            }\r\n        }\r\n    }\r\n}"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"buNjuQzHr4","position":{"x":-2530,"y":80},"sizes":{"width":399.765625,"height":77.4375},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Village.c "}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"// Village 100%\r\nint radius = 4; // 1 region : 512 chunk\r\nfor (int rx = -radius; rx < radius; rx++)\r\n{\r\n    for (int rz = -radius; rz < radius; rz++)\r\n    {\r\n        Pos p;\r\n\n        if (getStructurePos(Village, MC_1_16_1, seed, rx, rz, &p))\r\n        {\r\n            if (isViableStructurePos(Village, &g, p.x, p.z, 0))\r\n            {\r\n                printf(\"Village at (%d, %d)\\n\", p.x + 8, p.z + 8);\r\n            }\r\n        }\r\n    }\r\n}"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"c8jvfoauRA","position":{"x":-2010,"y":230},"sizes":{"width":399.765625,"height":231.90625},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type Structure"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Treasure"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Village"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shipwreck"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ruind_Portal"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bastion"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fortress"}]}]}]}]},"color":{"bgColor":"hsla(140, 76%, 82%, 1)","bgName":"green-l"},"nodeType":"block"},{"uid":"bGjNFhdR_c","position":{"x":-2530,"y":190},"sizes":{"width":399.765625,"height":77.4375},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shipwreck.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"// Shipwreck 50%\r\nint radius = 4; // 4 region : 512 chunk\r\nfor (int rx = -radius; rx < radius; rx++)\r\n{\r\n    for (int rz = -radius; rz < radius; rz++)\r\n    {\r\n        Pos p;\r\n\n        if (getStructurePos(Shipwreck, MC_1_16_1, seed, rx, rz, &p))\r\n        {\r\n            if (isViableStructurePos(Shipwreck, &g, p.x, p.z, 0))\r\n            {\r\n                printf(\"Shipwreck at (%d, %d)\\n\", p.x + 8, p.z + 8);\r\n            }\r\n            count++;\r\n        }\r\n    }\r\n}"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"ghDPztsv2Q","position":{"x":-2530,"y":300},"sizes":{"width":399.765625,"height":77.4375},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ruind_portal.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"// ruind portal 50%\r\nint radius = 1; // 1 region : 512 chunk\r\nint centerX = 0 >> 4;\r\nint centerZ = 0 >> 4;\r\n\n\nfor (int rx = centerX - radius; rx <= centerX + radius; rx++)\r\n{\r\n    for (int rz = centerZ - radius; rz <= centerZ + radius; rz++)\r\n    {\r\n\n        Pos p;\r\n\n        if (getStructurePos(Ruined_Portal, MC_1_16_5, seed, rx, rz, &p))\r\n        {\r\n            if (isViableStructurePos(Ruined_Portal, &g, p.x, p.z, 0))\r\n            {\r\n                printf(\"Ruined_Portal at (%d, %d)\\n\", p.x + 8, p.z + 8 );\r\n            }\r\n            count++;\r\n        }\r\n    }\r\n}"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"X2Uq2GjaTD","position":{"x":-2530,"y":400},"sizes":{"width":399.765625,"height":69.828125},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bastion.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"// bastion \r\nint radius = 3; // 1 region : 512\r\n// masalahnya radius 3 menjadi radius 2.5\r\nint centerX = 0 >> 4;\r\nint centerZ = 0 >> 4;\r\n\n\nfor (int rx = centerX - radius; rx <= centerX + radius; rx++)\r\n{\r\n    for (int rz = centerZ - radius; rz <= centerZ + radius; rz++)\r\n    {\r\n\n        Pos p;\r\n\n        if (getStructurePos(Bastion, MC_1_16_5, seed, rx, rz, &p))\r\n        {\r\n            if (isViableStructurePos(Bastion, &g, p.x, p.z, 0))\r\n            {\r\n                printf(\"Bastion at (%d, %d)\\n\", p.x + 8, p.z + 8 );\r\n            }\r\n            count++;\r\n        }\r\n    }\r\n}\r\n"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"c5FTRC4cNf","position":{"x":-2530,"y":510},"sizes":{"width":399.765625,"height":77.4375},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fortress.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"// fortress 60%\r\nint radius = 1 + 1; // 1 region : 512 chunk\r\n\r\nint centerX = 0 ;\r\nint centerZ = 0 ;\r\n\n\nfor (int rx = centerX - radius; rx < centerX + radius; rx++)\r\n{\r\n    for (int rz = centerZ - radius; rz < centerZ + radius; rz++)\r\n    {\r\n\n        Pos p;\r\n\n        if (getStructurePos(Fortress, MC_1_16_5, seed, rx, rz, &p))\r\n        {\r\n            if (isViableStructurePos(Fortress, &g, p.x, p.z, 0))\r\n            {\r\n                printf(\"Fortress at (%d, %d)\\n\", p.x, p.z  );\r\n                count++;\r\n            }\r\n        }\r\n    }\r\n}\r\n"}]}]},"color":{"bgColor":"hsla(214, 17%, 29%, 1)","bgName":"gray"},"nodeType":"block"},{"uid":"6PB-zfof_e","position":{"x":-2010,"y":500},"sizes":{"width":399.765625,"height":190.546875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Type Biome"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ocean"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Plains"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deep_Ocean"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forect"}]}]}]}]},"color":{"bgColor":"hsla(140, 76%, 82%, 1)","bgName":"green-l"},"nodeType":"block"},{"uid":"Z4SM5i-VlO","position":{"x":-2260,"y":1020},"sizes":{"width":859.515625,"height":615.375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Main Code"}]},{"type":"paragraph"},{"type":"codeBlock","attrs":{"language":"c","wrapCode":false},"content":[{"type":"text","text":"int main(int argc, char *argv[])\n{\n    long long seed = -7943827257158980320;\n\n    // membuat file json\n    char filename[100];\n    sprintf(filename, \"seed/%lld.json\", seed);\n    FILE *fp = fopen(filename, \"w\");\n\n    fprintf(fp, \"{\\n\");\n    fprintf(fp, \"  \\\"seed\\\": %lld,\\n\", seed);\n    fprintf(fp, \"  \\\"structures\\\": [\\n\");\n    Buah makanan = getStructure(seed, MC_1_16_1, Village, \"Village\", 1, DIM_OVERWORLD);\n    fprintf(fp,\"    { \\\"type\\\": \\\"%s\\\", \\\"x\\\": %d, \\\"z\\\": %d },\\n\", makanan.type, makanan.object_x, makanan.object_z);\n    \n    fprintf(fp, \"  ]\\n\");\n\n    fclose(fp);\n    printf(\"File %s berhasil dibuat (%d structure) (%d biomes)\\n\", filename);\n        \n\n    return 0;\n}\n\n"}]}]},"color":{"bgColor":"hsla(205, 100%, 87%, 1)","bgName":"blue-l"},"nodeType":"block"},{"uid":"1kfZu0jnyV","position":{"x":-1010,"y":1530},"sizes":{"width":1024.703125,"height":1119.484375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"c\\main002.c"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Membaca File JSON Lib cJSON"}]},{"type":"paragraph","content":[{"type":"text","text":"membaca file json dan mengecek jarak player dan object. apakah player jaraknya dekat dengan object"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"cJSON *structure = cJSON_GetObjectItem(json, \"structures\");\r\ncJSON *spawn_x = cJSON_GetArrayItem(cJSON_GetObjectItem(json, \"player\"), 0);\r\ncJSON *spawn_z = cJSON_GetArrayItem(cJSON_GetObjectItem(json, \"player\"), 1);\r\n\r\nprintf(\"player: %d, %d \\n\", spawn_x->valueint, spawn_z->valueint);\r\n\nint player_x = spawn_x->valueint;\r\nint player_z = spawn_z->valueint;\r\n\nint s_size = cJSON_GetArraySize(structure);\r\nprintf(\"structure: %d\\n\", s_size);\r\n\nfor (int i = 0; i < s_size; i++) {\r\n\n    // variaber type data\r\n    char *type =    cJSON_GetObjectItem(cJSON_GetArrayItem(cJSON_GetObjectItem(json, \"structures\"), i), \"type\")->valuestring;\r\n    int x_structure=cJSON_GetObjectItem(cJSON_GetArrayItem(cJSON_GetObjectItem(json, \"structures\"), i), \"x\")->valueint;\r\n    int z_structure=cJSON_GetObjectItem(cJSON_GetArrayItem(cJSON_GetObjectItem(json, \"structures\"), i), \"z\")->valueint;\r\n\n    \r\n\n    // cetak info\r\n    int object_r;\r\n    if (strcmp(\"bastion\", type) == 0)  object_r = 4 * 16;\r\n    if (strcmp(\"village\", type) == 0)  object_r = 12 * 16;\r\n    if (strcmp(\"ruind_portal\", type) == 0)  object_r = 1 * 16;\r\n    if (strcmp(\"fortress\", type) == 0)  object_r = 10 * 16;\r\n    if (strcmp(\"break\", type) == 0) break;\r\n    \r\n    printf(\"- %d %s\\n\", i, type); // \r\n    printf(\"- %d %d\\n\", i, x_structure); // \r\n    printf(\"- %d %d\\n\", i, z_structure); // \r\n\n    // validasi jarak max\r\n    int max_radius = 300;\r\n\n    int spawn_r = 300;\r\n\n    int dx = (x_structure - player_x);\r\n    int dy = (z_structure - player_z);\r\n    \r\n    if (dx < 0) dx = -1 * dx;\r\n    if (dy < 0) dy = -1 * dy;\r\n    \r\n    int r = spawn_r + object_r;\r\n\n    // return (dx <= r) && (dy <= r);\r\n    if ((dx <= r) && (dy <= r)) {\r\n        printf(\"true\\n\");\r\n    } else {\r\n        printf(\"false\\n\");\r\n    }\r\n    printf(\"\\n\");"}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"RE37eQnWMP","position":{"x":380,"y":2200},"sizes":{"width":399.765625,"height":282.734375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"jsonc.c"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Create FIle json"}]},{"type":"paragraph","content":[{"type":"text","text":"membuat file json dengan nama seed dan berisi informasi data seperti lokasi structure dan biome."}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"char filename[100];\r\nsprintf(filename, \"seed/%lld.json\", seed);\r\nFILE *fp = fopen(filename, \"w\");\r\n"}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"RuqW486cJo","position":{"x":-1970,"y":730},"sizes":{"width":399.765625,"height":265.21875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"jsonc.c"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Setup Cubiomes"}]},{"type":"paragraph","content":[{"type":"text","text":"setingan lokasi saat seed dimasukan seperti versi, generation, dan dimensi"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"Generator g;\r\nsetupGenerator(&g, MC_1_16_1, 0);\r\napplySeed(&g, DIM_OVERWORLD, seed);"}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"Vtw6U0IN9-","position":{"x":390,"y":1510},"sizes":{"width":629.5625,"height":629.34375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"biomes.c"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mengisi Code Json"}]},{"type":"paragraph","content":[{"type":"text","text":"membuat dan mengisi code program yang akan disimpan ke dalam file `seed/<seed>.json`"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"\nfprintf(fp, \"{\\n\");\r\nfprintf(fp, \"  \\\"seed\\\": %lld,\\n\", seed);\r\nfprintf(fp, \"  \\\"version\\\": \\\"1.16.1\\\",\\n\");\r\n\r\n// === Biomes JSON ===\r\nfprintf(fp, \"  \\\"biomes\\\": [\\n\");\r\nfor (int i = 0; i < totalBiome; i++) {\r\n    fprintf(fp,\r\n        \"    { \\\"type\\\": \\\"%s\\\", \\\"x\\\": %d, \\\"z\\\": %d }\",\r\n        biomes[i].type, biomes[i].x, biomes[i].z\r\n    );\r\n\n    if (i < totalBiome - 1)\r\n        fprintf(fp, \",\");\r\n\n    fprintf(fp, \"\\n\");\r\n}\r\nfprintf(fp, \"  ]\\n\");\r\n\nfprintf(fp, \"}\\n\");\r\nfclose(fp);\r\n\nprintf(\"File %s berhasil dibuat (%d biomes)\\n\",\r\n       filename, totalBiome);"}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"iPtMPOVXrY","position":{"x":840,"y":310},"sizes":{"width":749.640625,"height":846.421875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"c\\random.c"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Seed Random"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <stdint.h>\r\n#include <time.h>\r\n\r\nuint64_t state;\r\n\r\nuint64_t xorshift64() {\r\n    state ^= state << 13;\r\n    state ^= state >> 7;\r\n    state ^= state << 17;\r\n    return state;\r\n}\r\n\r\nchar* seed_random(int panjang) {\r\n    char* result = malloc(panjang + 2);\r\n    int index = 0;\r\n\r\n    // tanda + / -\r\n    if (xorshift64() % 2 == 0) {\r\n        result[index++] = '-';\n    }\n    for (int i = 0; i < panjang; i++) {\r\n        result[index++] = '0' + (xorshift64() % 10);\n    }\n    result[index] = '\\0';\r\n    return result;\r\n}\r\n\r\n\r\nint main() {\r\n    state = time(NULL); // seed awal\r\n\r\n    char* s = seed_random(19);\r\n    printf(\"%s\\n\", s);\r\n\r\n    free(s);\r\n    return 0;\r\n}"}]}]},"color":{"bgColor":"hsla(45, 100%, 82%, 1)","bgName":"yellow-l"},"nodeType":"block"},{"uid":"5RDW0jO0tv","position":{"x":290,"y":320},"sizes":{"width":399.765625,"height":221.21875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Seed_random()"}]},{"type":"paragraph","content":[{"type":"text","text":"Function ini digunakan untuk membuat angka acak dalam bentuk seed random sepanjang 19 kata dengan bilangan positif dan negaif"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"panjang int"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"output seed random type char "}]}]},"color":{"bgColor":"hsla(261, 26%, 26%, 1)","bgName":"purple"},"nodeType":"block"},{"uid":"ci31rxtRUj","position":{"x":-3270,"y":1020},"sizes":{"width":729.640625,"height":811.40625},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"c\\main001.c"}]},{"type":"paragraph","content":[{"type":"text","text":"membuat dan memasukan nilai di dalam file bin"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"#include <stdio.h>\n#include <string.h>\n\ntypedef struct {\n    char type[20];\n    int x;\n    int z;\n} Data;\n\nint main() {\n    FILE *file = fopen(\"data.bin\", \"wb\");\n\n    if (!file) {\n        printf(\"Gagal buka file\\n\");\n        return 1;\n    }\n\n    Data res;\n\n    // 🔥 LOOP X dan Z\n    for (int x = 1; x < 10; x++) {\n        for (int z = 0; z < 10; z++) {\n\n            strcpy(res.type, \"ocean\"); // ✅ BENAR\n            res.x = x;\n            res.z = z;\n\n            fwrite(&res, sizeof(Data), 1, file); // ✅ BENAR\n        }\n    }\n\n    fclose(file);\n\n    printf(\"Data berhasil disimpan!\\n\");\n    return 0;\n}\r\n"}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"fFp5QZl8y2","position":{"x":-3180,"y":1970},"sizes":{"width":599.640625,"height":513.828125},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"c\\main001.c"}]},{"type":"paragraph","content":[{"type":"text","text":"membaca file bin"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"\n#include <stdio.h>\n\ntypedef struct {\n    char type[20];\n    int x;\n    int z;\n} Data;\n\nint main() {\n    FILE *file = fopen(\"data.bin\", \"rb\");\n\n    Data res;\n\n    while (fread(&res, sizeof(Data), 1, file)) {\n        printf(\"type=%s x=%d z=%d\\n\", res.type, res.x, res.z);\n    }\n\n    fclose(file);\n}   "}]}]},"color":{"bgColor":"hsla(5, 100%, 88%, 1)","bgName":"red-l"},"nodeType":"block"},{"uid":"mtBdwO3wnc","position":{"x":-2330,"y":1850},"sizes":{"width":419.640625,"height":214.21875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"File bin"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File "},{"type":"text","marks":[{"type":"code"}],"text":"bin"},{"type":"text","text":"adalah file yang berisi data mentah dalam bentuk "},{"type":"text","marks":[{"type":"bold"}],"text":"byte (0 dan 1) "},{"type":"text","text":"file yang menyimpan data langsung dari memory komputer dalam bentuk biner tanpa format teks."},{"type":"text","marks":[{"type":"bold"}],"text":" "},{"type":"text","text":"bukan teks yang bisa dibaca manusia."}]},{"type":"paragraph"}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"UxfFMHHnE8","position":{"x":-1140,"y":680},"sizes":{"width":889.703125,"height":573.359375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"fungsi.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"const char* LocationBiome(FILE *fp, long long seed, int mc, int BiomeType, char *type, int radius, int dimension ) \r\n{   \r\n    Generator g;\r\n    setupGenerator(&g, mc, 0);\r\n    applySeed(&g, dimension, seed);\r\n    int totalBiome = 0;\r\n    printf(\"Mencari biome dalam radius %d block...\\n\", radius);\r\n\r\n    for (int X = -radius; X <= radius; X += 16)\r\n    {\r\n        for (int Z = -radius; Z <= radius; Z += 16)\r\n        {\r\n            int biomeID = getBiomeAt(&g, 1, X, 0, Z);\r\n            \r\n            if (biomeID == BiomeType)\r\n            {\r\n                printf(\"%s location X= %d Z= %d\\n\", type, X, Z);\r\n                fprintf(fp, \"\\t\\t{\\\"type\\\": \\\"%s\\\", \\\"x\\\": %d, \\\"z\\\": %d},\\n\", type, X, Z);\r\n                res.type = 1; // bebas (misalnya jenis structure)\r\n                res.x = x;\r\n                res.z = z;\r\n            }\r\n        }\r\n    }\r\n}"}]}]},"color":{"bgColor":"hsla(33, 94%, 80%, 1)","bgName":"orange-l"},"nodeType":"block"},{"uid":"ZFgm53fKvC","position":{"x":-140,"y":640},"sizes":{"width":399.765625,"height":306.828125},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"LocationBiome()"}]},{"type":"paragraph","content":[{"type":"text","text":"function ini akan mencari loaksi biome sesuai dengan methot yang dimasukan oleh users."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File FILE"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Seed int"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Version int"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Biome int"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"type char"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"radius int"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"typ
{"id":-1,"name":"Onboarding diagram","userId":-1,"createdAt":"","updatedAt":"","content":{"items":[{"uid":"8FX8zhZvfx","position":{"x":320,"y":610},"sizes":{"width":189.5625,"height":86.84375},"autoheight":true,"blockContent":{"text":"function ini akan membuat lokasi structure sesuai dengan methot yang dimasukan oleh users."},"nodeType":"text"},{"uid":"mlbspGVfJA","position":{"x":-1080,"y":50},"sizes":{"width":769.5,"height":573.359375},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"filePathNode","attrs":{"pathToFile":"","version":1},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"fungsi.c"}]},{"type":"codeBlock","attrs":{"language":"c","wrapCode":true},"content":[{"type":"text","text":"const char* LocationStructure(FILE *fp, long long seed, int mc, int StructureType, char *type, int radius, int dimension ) \n{\n    Generator g;\n    Pos spawn = getSpawn(&g);\n    setupGenerator(&g, mc, 0);\n    applySeed(&g, dimension, seed);\n    for (int rx = -radius; rx <= radius; rx++)\n    {\n        for (int rz = -radius; rz <= radius; rz++)\n        {\n            Pos p;\n\n            if (getStructurePos(StructureType, mc, seed, rx, rz, &p))\n            {\n                if (isViableStructurePos(StructureType, &g, p.x, p.z, 0))\n                {\n                    printf(\"%s at (%d, %d)\\n\", type, p.x, p.z);\n                    fprintf(fp, \"\\t\\t{\\\"type\\\": \\\"%s\\\", \\\"x\\\": %d, \\\"z\\\": %d},\\n\", type, p.x, p.z);\n                }\n            }\n        }\n    }\n}\n"}]}]},"color":{"bgColor":"hsla(33, 94%, 80%, 1)","bgName":"orange-l"},"nodeType":"block"},{"uid":"kPPMlxmSq7","position":{"x":-2580,"y":890},"sizes":{"width":249.578125,"height":23.859375},"autoheight":true,"blockContent":{"text":"text"},"nodeType":"text"},{"uid":"2S0eS4e881","position":{"x":-140,"y":320},"sizes":{"width":399.765625,"height":299.640625},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"conten